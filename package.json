  "scripts": {
    "lint": "eslint --ext .js,.vue ./",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "deploy": "quasar build && mkdir -p deploy && cp -R dist/spa/* deploy && node_modules/git-directory-deploy/bin/git-directory-deploy.sh -ddeploy -bgh-pages -rgit@github.com:flespi-software/MediaBox.git",
    "build": "quasar build"
  },
  "dependencies": {

    "@quasar/extras": "^1.16.4",
    "axios": "^1.2.1",
    "flespi-io-js": "git+https://github.com/flespi-software/flespi-io-js.git#v3",
    "form-data": "^4.0.0",
    "git-directory-deploy": "^1.5.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mpegts.js": "^1.8.0",
    "mqtt": "^5.1.3",
    "pinia": "^2.0.11",
    "quasar": "^2.6.0",
    "vue": "^3.0.0",
    "vue-i18n": "^9.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.23.3",
    "@intlify/vite-plugin-vue-i18n": "^3.3.1",
    "@quasar/app-vite": "^1.3.0",

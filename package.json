{
  "name": "mediabox",
  "version": "0.1.0",
  "description": "Vue 3 + Quasar web app for viewing and managing media files from flespi IoT devices",
  "productName": "MediaBox",
  "author": "Evgenij Spitsyn <spev@gurtam.com>",
  "license": "MIT",
  "homepage": "https://github.com/flespi-software/MediaBox#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flespi-software/MediaBox.git"
  },
  "bugs": {
    "url": "https://github.com/flespi-software/MediaBox/issues"
  },
  "keywords": [
    "flespi",
    "iot",
    "telematics",
    "media",
    "video",
    "vue",
    "quasar",
    "mqtt"
